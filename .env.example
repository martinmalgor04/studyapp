# =============================================================================
# StudyApp - Variables de Entorno
# Copiá este archivo como .env.local y completá los valores
# =============================================================================

# --- Supabase (REQUERIDO) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- App URL (REQUERIDO) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase interno (solo para Docker) ---
# SUPABASE_INTERNAL_URL=http://supabase:8000

# --- Google Calendar (OPCIONAL) ---
# Obtené en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# --- Resend (OPCIONAL - para emails) ---
# Obtené en: https://resend.com/
RESEND_API_KEY=

# =============================================================================
# PRODUCCIÓN: reemplazá los valores por los de Supabase Cloud y Vercel
# NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-de-produccion
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com
# =============================================================================
